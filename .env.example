# Example environment variables for Racetrack Info Screens
# Copy this file to .env and fill in your own values

RECEPTIONIST_KEY=your_receptionist_key
SAFETY_KEY=your_safety_key
OBSERVER_KEY=your_observer_key
# Optional: set to 'true' for 1-minute races in dev
RACE_DEV_MODE=true
# Optional: change server port (default 3000)
PORT=3000
